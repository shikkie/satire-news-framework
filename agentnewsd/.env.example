# Copy to .env and set a strong secret:
#   cp agentnewsd/.env.example agentnewsd/.env
#   # edit AGENTNEWSD_API_KEY

# Required — single shared API key for POST /v1/create-article
AGENTNEWSD_API_KEY=change-me-to-a-long-random-secret

# Bind address: 0.0.0.0 = all interfaces (remote clients). Use 127.0.0.1 for local-only.
AGENTNEWSD_HOST=0.0.0.0
AGENTNEWSD_PORT=8790

# Max wall time for one create-article.sh run (seconds)
AGENTNEWSD_TIMEOUT_SECONDS=3600

# Max UTF-8 size of article_def JSON field
AGENTNEWSD_MAX_ARTICLE_DEF_BYTES=262144

# Optional overrides (defaults: parent of agentnewsd/ and scripts/create-article.sh)
# AGENTNEWSD_REPO_ROOT=/path/to/satire-news-framework
# AGENTNEWSD_CREATE_SCRIPT=/path/to/satire-news-framework/scripts/create-article.sh

# Grok CLI (inherited by create-article.sh)
# GROK_BIN=grok
# GROK_MODEL=grok-4.5
